# ── Sao chép file này thành .env và điền thông tin thật ──────────────────────

# URL ngrok do bạn AI cung cấp (không có dấu / ở cuối)
AI_API_URL=https://xxxx.ngrok-free.app

# API key do bạn AI cung cấp
AI_API_KEY=your-api-key-here

# Thư mục lưu file WAV (tương đối so với main.py)
AUDIO_DIR=audio_files

# Database path
DATABASE_URL=sqlite:///./tts_history.db

# CORS: thay bằng origin frontend nếu cần giới hạn
# CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]
